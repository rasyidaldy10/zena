# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Groq API (for Voice Note transcription)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Brick.co Open Banking API
# ⚠️ SECURITY: Do NOT put real credentials here!
# Real credentials go in Supabase Dashboard → Secrets (server-side only)
# This file is for CLIENT-SIDE env vars only (safe to commit)
BRICK_CLIENT_ID=your_brick_client_id_here
BRICK_REDIRECT_URI=zena://brick-callback
BRICK_ENVIRONMENT=sandbox

# ❌ DO NOT ADD BRICK_CLIENT_SECRET HERE!
# It must ONLY exist in Supabase secrets (server-side)

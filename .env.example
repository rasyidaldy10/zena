# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Groq API (for Voice Note transcription)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Brick.co Open Banking API
BRICK_CLIENT_ID=your_brick_client_id_here
BRICK_CLIENT_SECRET=your_brick_client_secret_here

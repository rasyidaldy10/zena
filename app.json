{
  "expo": {
    "name": "zena",
    "slug": "zena",
    "scheme": "zena",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.rasyid.zena",
      "buildNumber": "4",
      "supportsTablet": true
    },
    "android": {
      "package": "com.rasyid.zena",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#185FA5",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Zena",
      "shortName": "Zena",
      "description": "Keuanganmu, selaras.",
      "backgroundColor": "#0F0F0F",
      "themeColor": "#185FA5",
      "lang": "id",
      "scope": "/",
      "startUrl": "/(tabs)",
      "display": "standalone",
      "orientation": "portrait",
      "preferRelatedApplications": false
    },
    "plugins": [
      "expo-web-browser",
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8a920606-fca0-479d-b008-0e45421197a4"
      }
    },
    "owner": "rasyidaldy"
  }
}
